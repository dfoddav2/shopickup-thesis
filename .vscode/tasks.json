{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "LaTeX: Build PDF",
      "type": "shell",
      "command": "latexmk",
      "args": [
        "-pdf",
        "-shell-escape",
        "-interaction=nonstopmode",
        "-synctex=1",
        "-outdir=out",
        "shopickup-thesis.tex"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "LaTeX: Watch PDF",
      "type": "shell",
      "command": "latexmk",
      "args": [
        "-pdf",
        "-shell-escape",
        "-pvc",
        "-interaction=nonstopmode",
        "-synctex=1",
        "-outdir=out",
        "shopickup-thesis.tex"
      ],
      "isBackground": true,
      "group": "build",
      "problemMatcher": []
    }
  ]
}
